# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
WEBHOOK_URL=https://your-service.run.app
WEBHOOK_SECRET_PATH=webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=your_webhook_secret
USE_POLLING=false

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# === Google / Vertex AI (no API key — uses Application Default Credentials) ===
# Local dev: run `gcloud auth application-default login` once.
# Cloud Run: default service account needs roles/aiplatform.user.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global  # `global` works for Gemini 3 preview models

# === MiniMax (primary provider for TEXT/IMAGE/FILE + BAML routing) ===
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01

# === AI Provider Selection ===
# Default is "minimax". VOICE and VIDEO are hard-pinned to gemini (Vertex AI)
# in code — MiniMax does not support audio transcription or video understanding.
AI_PROVIDER=minimax
# Per-feature overrides (optional)
# AI_PROVIDER_TEXT=minimax
# AI_PROVIDER_IMAGE=minimax
# AI_PROVIDER_FILE=minimax
# Gemini models for VOICE/VIDEO (defaults shown)
GEMINI_MODEL_PRIMARY=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-3.1-pro-preview

# === TinyFish ===
TINYFISH_API_KEY=your_tinyfish_api_key

# === Spotify (optional) ===
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# === Server ===
HOST=0.0.0.0
PORT=8080

# === Export / NotebookLM (optional) ===
NOTEBOOKLM_NOTEBOOK_ID=
GDRIVE_FOLDER_ID=
GOOGLE_CREDENTIALS_PATH=
