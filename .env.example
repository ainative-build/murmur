# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
WEBHOOK_URL=https://your-service.run.app
WEBHOOK_SECRET_PATH=webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=your_webhook_secret
USE_POLLING=false

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# === Google / Gemini ===
GEMINI_API_KEY=your_gemini_api_key           # Local dev only; Cloud Run uses Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id    # Required for Cloud Run (Vertex AI)
GOOGLE_CLOUD_LOCATION=us-central1

# === MiniMax (new) ===
MINIMAX_API_KEY=your_minimax_api_key         # Required when AI_PROVIDER_* = minimax
MINIMAX_BASE_URL=https://api.minimax.io/v1  # Override for custom endpoint

# === AI Provider Selection ===
# Global default; per-feature vars take precedence. Valid values: gemini | minimax
AI_PROVIDER=gemini
# Per-feature overrides (optional; default is gemini for all)
AI_PROVIDER_TEXT=gemini
AI_PROVIDER_IMAGE=gemini
AI_PROVIDER_FILE=gemini
AI_PROVIDER_VOICE=gemini
AI_PROVIDER_VIDEO=gemini     # Always gemini in code; MiniMax has no video input
AI_PROVIDER_ROUTING=gemini   # BAML routing — always gemini in this release
# Model overrides (optional; defaults shown)
GEMINI_MODEL_PRIMARY=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-3.1-pro-preview
MINIMAX_MODEL=minimax-m2.7
MINIMAX_STT_MODEL=#g1_whisper-large

# === TinyFish ===
TINYFISH_API_KEY=your_tinyfish_api_key

# === Spotify (optional) ===
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# === Server ===
HOST=0.0.0.0
PORT=8080

# === Export / NotebookLM (optional) ===
NOTEBOOKLM_NOTEBOOK_ID=
GDRIVE_FOLDER_ID=
GOOGLE_CREDENTIALS_PATH=
